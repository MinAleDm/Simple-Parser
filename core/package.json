{
  "name": "simple-parser",
  "version": "2.0.0",
  "description": "Typed HTML parser/analyzer with CLI support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "bin": {
    "simple-parser": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "commander": "^14.0.1",
    "domhandler": "^5.0.3",
    "htmlparser2": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3"
  }
}
